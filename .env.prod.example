# =================================================================
# Arquivo de configuração para PRODUÇÃO
# NUNCA versionae este arquivo - crie uma cópia local com os valores reais
# =================================================================

# Google OAuth 2.0
GOOGLE_CLIENT_ID=seu_production_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_production_client_secret

# URL de redirecionamento após autenticação
REDIRECT_URL=https://seu-dominio.com/auth/callback

# JWT Secret - IMPORTANTE: use valor forte e aleatório (mínimo 32 caracteres)
JWT_SECRET=seu_jwt_secret_aleatorio_minimo_32_caracteres

# Redis Configuration com autenticação obrigatória
REDIS_ADDR=redis-host:6379
REDIS_PASSWORD=sua_senha_redis_forte

# Ambiente
ENVIRONMENT=production

# Porta (opcional, padrão: 8080)
PORT=8080

# CORS - Origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com

# TMDB API Key (opcional)
TMDB_API_KEY=sua_tmdb_api_key

# BASE URL para links absolutos
BASE_URL=https://seu-dominio.com

# Logging
LOG_LEVEL=info
