# Google OAuth 2.0 Configuration
# Obtenha em: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=sua_client_secret_aqui

# URL de redirecionamento após autenticação OAuth
# Para desenvolvimento local, use: http://localhost:8080/auth/callback
# Para produção, ajuste conforme necessário
REDIRECT_URL=http://localhost:8080/auth/callback

# JWT Secret para assinar tokens de sessão
# Use pelo menos 32 caracteres aleatórios
# Exemplo: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_minimo_32_caracteres_aleatorios

# Redis Configuration COM AUTENTICAÇÃO OBRIGATÓRIA
# Endereço do servidor Redis para cache
REDIS_ADDR=localhost:6379
# Senha do Redis (obrigatória por segurança)
REDIS_PASSWORD=sua_senha_redis_forte

# CORS - Origens permitidas (separadas por vírgula)
# Exemplos: http://localhost:3000,http://localhost:8080
# Em produção, use apenas seus domínios
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# Ambiente (development, production)
ENVIRONMENT=development

# Port (opcional, padrão: 8080)
PORT=8080

# TMDB API Key (opcional, se usar integrações TMDB)
# TMDB_API_KEY=sua_api_key_tmdb

# BASE URL (opcional, para links absolutos)
# BASE_URL=http://localhost:8080

# User Email Encrypt
LIST_SHARE_SECRET=sua_chave_secreta_minimo_32_caracteres_aleatorios